---
// @components/page/Footer.astro
import NewsArchive from '@components/NewsArchive.astro';
import { siteMetadata } from '@config/siteMetadata';
import FormFooter from './FormFooter.astro';
import SocialLinks from './SocialLinks.astro';

const year = new Date().getUTCFullYear();
---

<footer class="footer">
  <div class="wrapper footer__columns">
    <div class="footer__left">
      <FormFooter />
    </div>
    <div class="footer__right">
      <NewsArchive limit={8} />
      <div class="footer__social">
        <h2>Connect With Us</h2>
        <SocialLinks />
      </div>
    </div>
  </div>
  <div class="wrapper copyright">
    <p>&copy; &nbsp;{year} {siteMetadata.name} - All Rights Reserved</p>
  </div>
</footer>
<style>
  .footer {
    margin-block-start: var(--size-fluid-5);
    background: var(--color-dark);
    color: var(--gray-1);
  }

  .footer__columns {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-l);
    padding-block: var(--space-l);
  }

  @media (max-width: 600px) {
    .footer__columns {
      grid-template-columns: 1fr;
    }
  }

  .footer__social {
    padding-block-start: var(--space-m);
  }

  .footer__social h2 {
    font-size: var(--step-1);
    margin-block-end: var(--space-s);
    color: var(--gray-1);
  }

  .copyright {
    background: var(--color-darker);
    padding-block: var(--space-s);
  }

  .copyright p {
    margin: 0;
    font-size: var(--step--1);
    color: var(--gray-4);
    text-align: center;
  }
</style>
